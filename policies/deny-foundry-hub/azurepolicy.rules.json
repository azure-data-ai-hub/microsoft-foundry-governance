{
  "if": {
    "allOf": [
      {
        "field": "type",
        "equals": "Microsoft.MachineLearningServices/workspaces"
      },
      {
        "field": "Microsoft.MachineLearningServices/workspaces/kind",
        "equals": "Hub"
      }
    ]
  },
  "then": {
    "effect": "[parameters('effect')]"
  }
}
